# Database
DATABASE_URL=postgresql://user:password@localhost:5432/the_record

# NextAuth
# NEXTAUTH_URL is auto-detected on Vercel. Set manually for other environments.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=the-record-uploads

# Encryption (development only — production uses AWS Secrets Manager)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# AWS Secrets Manager (production only)
AWS_SECRETS_MANAGER_KEY_ARN=
