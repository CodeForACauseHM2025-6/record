generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  READER
  WRITER
  DESIGNER
  EDITOR
  WEB_TEAM
  WEB_MASTER
}

enum Section {
  NEWS
  OPINIONS
  LIONS_DEN
  A_AND_E
  FEATURES
  THE_ROUNDTABLE
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  image         String?
  googleImage   String?
  emailVerified DateTime?
  role          Role      @default(READER)
  displayTitle  String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  articles       Article[]
  articleCredits ArticleCredit[]
  accounts       Account[]
  sessions       Session[]
  approvals      Approval[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Article {
  id            String        @id @default(uuid())
  title         String        @db.VarChar(300)
  slug          String        @unique
  body          String
  excerpt       String?       @db.VarChar(500)
  featuredImage String?
  section       Section
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdById   String

  groupId     String

  createdBy  User           @relation(fields: [createdById], references: [id])
  group      ArticleGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  credits    ArticleCredit[]
  images     ArticleImage[]
  blockSlots BlockSlot[]
  approvals  Approval[]
}

model ArticleCredit {
  id         String @id @default(uuid())
  articleId  String
  userId     String
  creditRole String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([articleId, userId, creditRole])
}

model ArticleImage {
  id        String  @id @default(uuid())
  articleId String
  url       String
  caption   String?
  altText   String
  order     Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model SiteSetting {
  key   String @id
  value String
}

model ArticleGroup {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(200)
  issueNumber  String?   @db.VarChar(20)
  status       ArticleStatus @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  blocks    LayoutBlock[]
  articles  Article[]
  approvals Approval[]
}

model LayoutBlock {
  id           String  @id @default(uuid())
  groupId      String
  column       String  // "main" | "sidebar"
  pattern      String  // pattern ID from registry
  order        Int
  dividerStyle String  @default("light") // "light" | "bold" | "none"

  group  ArticleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  slots  BlockSlot[]
}

model BlockSlot {
  id          String  @id @default(uuid())
  blockId     String
  slotRole    String  // "article" | "headline" | "image" | "media"
  order       Int
  articleId   String?
  mediaUrl    String?
  mediaType   String?
  mediaAlt    String?
  mediaCredit String?
  scale       String  @default("M") // "S" | "M" | "L" | "XL"
  imageScale  String  @default("M") // "S" | "M" | "L" | "XL"
  previewLength Int     @default(200)
  featured      Boolean @default(false)
  showByline    Boolean @default(true)
  imageFloat    String  @default("full") // "left" | "right" | "full"
  imageWidth    Int     @default(100) // 10-100 percentage of container
  imageCrop     String  @default("original") // "original" | "landscape" | "portrait" | "square" | "custom"
  imageCropCustom String? // e.g. "16:9" for custom ratio

  block   LayoutBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  article Article?    @relation(fields: [articleId], references: [id])
}

model Approval {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())

  articleId String?
  groupId   String?

  user    User          @relation(fields: [userId], references: [id])
  article Article?      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  group   ArticleGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@unique([userId, groupId])
}
